{
  "name": "hello.say",
  "version": "1.0.0",
  "description": "A greeting CLI for testing pipeline functionality",
  "inputs": [
    {"name": "name", "type": "STRING", "required": false, "default": "World", "description": "Name to greet"},
    {"name": "greeting", "type": "STRING", "required": false, "default": "Hello", "description": "Greeting word"},
    {"name": "repeat", "type": "INT", "required": false, "default": "1", "description": "Number of times to repeat"},
    {"name": "input_data", "type": "STREAM", "required": false, "description": "Pipeline input stream"}
  ],
  "outputs": [
    {"name": "message", "type": "TEXT", "description": "Greeting text"},
    {"name": "structured", "type": "STRUCT", "description": "Structured greeting data"}
  ],
  "resources": {"cpu_cores": 0.1, "memory_mb": 16, "disk_mb": 10},
  "network": "none",
  "image_ref": "ghcr.io/unicli/hello.say:1.0.0",
  "entrypoint": "/bin/say",
  "workdir": "/workspace"
}
